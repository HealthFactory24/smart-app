{
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[less]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[markdown]": {
		"editor.defaultFormatter": "vscode.markdown-language-features",
		"editor.quickSuggestions": {
			"comments": "off",
			"other": "off",
			"strings": "off"
		},
		"editor.wordWrap": "on"
	},
	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma",
		"editor.formatOnSave": true
	},
	"[scss]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	// Biome as linter
	"biome.lsp.bin": "node_modules/@biomejs/biome/bin/biome",
	"biome.requireConfiguration": true,
	"debug.console.fontSize": 13,
	"debug.console.lineHeight": 1.3,
	"debug.internalConsoleOptions": "neverOpen",
	"debug.openDebug": "openOnSessionStart",
	"debug.showInStatusBar": "always",
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.renderSideBySide": true,
	"diffEditor.wordWrap": "off",
	"editor.acceptSuggestionOnEnter": "on",
	"editor.codeActionsOnSave": {
		"source.addMissingImports.ts": "explicit",
		"source.fixAll.biome": "always",
		"source.organizeImports": "always",
		"source.removeUnusedImports": "explicit",
		"source.sort.json": "explicit"
	},
	"editor.codeLens": true, // Disable for performance
	"editor.colorDecorators": true,
	// Since you're switching to Biome, use Biome as default formatter
	"editor.defaultFormatter": "biomejs.biome",
	"editor.detectIndentation": false,
	"editor.experimental.preferTreeSitter.typescript": true,
	"editor.folding": true,
	"editor.foldingStrategy": "auto",
	"editor.formatOnPaste": false,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"editor.formatOnType": false,
	"editor.glyphMargin": true,
	"editor.hideCursorInOverviewRuler": false,
	"editor.hover.enabled": "on",
	"editor.hover.sticky": true, // Disable for performance
	"editor.insertSpaces": true,
	"editor.largeFileOptimizations": true,
	"editor.lightbulb.enabled": "off", // Disable for performance
	"editor.lineNumbers": "on",
	"editor.maxTokenizationLineLength": 20000,
	"editor.occurrencesHighlight": "multiFile",
	"editor.overviewRulerBorder": false,
	"editor.quickSuggestionsDelay": 10,
	"editor.renderControlCharacters": true,
	"editor.renderFinalNewline": "on",
	"editor.renderWhitespace": "boundary",
	"editor.rulers": [80, 100, 120],
	"editor.selectionHighlight": true,
	"editor.snippetSuggestions": "top",
	"editor.suggest.snippetsPreventQuickSuggestions": false,
	"editor.suggestOnTriggerCharacters": true,
	"editor.tabCompletion": "on",
	"editor.tabSize": 2,
	"editor.wordBasedSuggestions": "off", // Disable for performance
	"editor.wordWrap": "off",
	"emmet.includeLanguages": {
		"javascript": "javascriptreact",
		"typescript": "typescriptreact"
	},
	"emmet.showExpandedAbbreviation": "always",
	"emmet.triggerExpansionOnTab": true,
	"explorer.compactFolders": false,
	"explorer.confirmDelete": true,
	"explorer.confirmDragAndDrop": true,
	// Nest config files together in the explorer
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"docker-compose.yaml": ".dockerignore, Dockerfile*, docker-compose.*.yaml, .env.docker*",
		"package.json": "LICENSE, package-lock.json, renovate.*, .npmrc, knip.*, .node-version, pnpm*, components.json, commitlint*, .nvmrc, .yarnrc*, yarn*, .eslint*, eslint*, .prettier*, prettier*, .editorconfig, .gitattributes, .gitignore, bun.lock",
		"router.tsx": "routeTree.gen.ts",
		"tsconfig.json": "tsconfig.*.json, env.d.ts",
		"vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*"
	},
	"explorer.incrementalNaming": "smart",
	"explorer.sortOrder": "type", // Folders first
	"extensions.autoUpdate": true,
	"extensions.closeExtensionDetailsOnViewChange": true,
	"extensions.ignoreRecommendations": true,
	"files.associations": {
		"*.css": "tailwindcss",
		"*.js": "javascript",
		"*.jsx": "javascriptreact",
		"*.prisma": "prisma",
		"*.scss": "postcss",
		"*.ts": "typescript",
		"*.tsx": "typescriptreact"
	},
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 1000,
	"files.encoding": "utf8",
	"files.eol": "\n", // LF for consistency
	"files.exclude": {
		"**/.DS_Store": true,
		"**/.git": true,
		"**/.hg": true,
		"**/.next": true,
		"**/.svn": true,
		"**/.turbo": true,
		"**/build": true,
		"**/CVS": true,
		"**/dist": true,
		"**/node_modules": true,
		"**/Thumbs.db": true
	},
	"files.insertFinalNewline": true,
	"files.readonlyInclude": {
		"**/routeTree.gen.ts": true
	},
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.next/**": true,
		"**/.tanstack/**": true,
		"**/.turbo/**": true,
		"**/build/**": true,
		"**/data/**": true,
		"**/dist/**": true,
		"**/node_modules/**": true
	},
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.inputValidation": true,
	"git.inputValidationLength": 72,
	"git.inputValidationSubjectLength": 50,
	"js/ts.autoClosingTags.enabled": false,
	"js/ts.experimental.useTsgo": true,
	"js/ts.format.enabled": true,
	"js/ts.preferences.importModuleSpecifier": "relative",
	"js/ts.preferences.importModuleSpecifierEnding": "minimal",
	"js/ts.preferences.organizeImports": {
		"sortImportDeclarations": true,
		"sortImportMembers": true,
		"sortImportSpecifiers": true
	},
	"js/ts.preferences.quoteStyle": "single",
	"js/ts.preferGoToSourceDefinition": true,
	"js/ts.suggest.autoImports": true,
	"js/ts.suggest.completeFunctionCalls": true,
	"js/ts.tsdk.path": "node_modules/typescript/lib",
	"js/ts.tsdk.promptToUseWorkspaceVersion": true,
	"js/ts.tsserver.experimental.enableProjectDiagnostics": true,
	"js/ts.tsserver.maxMemory": 4096, // Increase for large projects
	"js/ts.tsserver.watchOptions": {
		"fallbackPolling": "dynamicPriorityPolling",
		"watchDirectory": "useFsEvents",
		"watchFile": "useFsEvents"
	},
	"js/ts.updateImportsOnFileMove.enabled": "always",
	"json.schemas": [
		{
			"fileMatch": ["fhir/*.json"],
			"url": "https://json.schemastore.org/fhir.schema.json"
		}
	],
	"kiroAgent.configureMCP": "Disabled",
	"outline.problems.enabled": true,
	"output.smartScroll.enabled": true,
	"path-autocomplete.disableUpOneFolder": true,
	"prisma.pinToPrisma6": false,
	"problems.autoReveal": true,
	"problems.showCurrentInStatus": true,
	"search.exclude": {
		"**/.git": true,
		"**/.next": true,
		"**/.turbo": true,
		"**/bower_components": true,
		"**/build": true,
		"**/coverage": true,
		"**/dist": true,
		"**/node_modules": true
	},
	"search.followSymlinks": false, // Performance
	"search.quickOpen.includeHistory": false,
	"search.useIgnoreFiles": true,
	"tailwindcss-intellisense.trace.server": "verbose",
	"tailwindCSS.emmetCompletions": true,
	"tailwindCSS.experimental.classRegex": [
		["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
		["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
		["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
	],
	"tailwindCSS.includeLanguages": {
		"javascript": "javascript",
		"javascriptreact": "javascript",
		"typescript": "javascript",
		"typescriptreact": "javascript"
	},
	"tailwindCSS.lint.cssConflict": "warning",
	"tailwindCSS.lint.invalidConfigPath": "error",
	"tailwindCSS.lint.invalidScreen": "error",
	"tailwindCSS.lint.invalidVariant": "error",
	"tailwindCSS.lint.recommendedVariantOrder": "warning",
	"tailwindCSS.validate": true,
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'Fira Code', Monaco, 'Courier New', monospace",
	"terminal.integrated.fontSize": 13,
	"terminal.integrated.lineHeight": 1.2,
	"terminal.integrated.rightClickBehavior": "selectWord",
	"terminal.integrated.shellIntegration.enabled": true,
	"terminal.integrated.shellIntegration.environmentReporting": true,
	"terminal.integrated.suggest.enabled": true,
	"terminal.integrated.suggest.quickSuggestions": {
		"arguments": "on",
		"commands": "on",
		"unknown": "off"
	},
	"typescript.tsdk": "node_modules/typescript/lib",
	"window.closeWhenEmpty": false,
	"window.newWindowDimensions": "maximized",
	"window.restoreWindows": "all",
	"window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${profileName}",
	"workbench.colorTheme": "Dark 2026",
	"workbench.editor.closeOnFileDelete": true,
	"workbench.editor.enablePreview": true,
	"workbench.editor.enablePreviewFromQuickOpen": false,
	"workbench.editor.openPositioning": "right",
	"workbench.editor.pinnedTabSizing": "normal",
	"workbench.editor.tabSizing": "shrink",
	"workbench.editor.wrapTabs": true,
	"workbench.iconTheme": "material-icon-theme", // If installed
	"workbench.list.smoothScrolling": true,
	"workbench.productIconTheme": "Default", // If installed
	"workbench.settings.editor": "json",
	"workbench.settings.enableNaturalLanguageSearch": false,
	"workbench.settings.useSplitJSON": true,
	"workbench.startupEditor": "none",
	"workbench.tree.indent": 16,
	"workbench.tree.renderIndentGuides": "always"
}
