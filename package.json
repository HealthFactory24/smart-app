  "name": "tanstack-2-stackshopapp",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "private": true,
  "scripts": {
    "add-ui-components": "bunx --bun shadcn@latest add ",
    "auth:generate": "bunx @better-auth/cli generate --config ./src/lib/auth/auth.ts --output ./src/lib/db/schema/auth.ts",
    "build": "vite build",
    "check": "biome check --write",
    "check:fix": "biome check --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:neon-setup": "bunx neondb",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run ./src/db/seed.ts",
    "db:setup-vector": "bun --env-file=.env run ./scripts/setup-vector-extension.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "vite dev --port 3000",
    "email:dev": "email dev --dir src/components/emails --port 5555",
    "format": "biome format --write",
    "gen": "bun generate ",
    "generate": "bunx @tanstack/router-cli generate ",
    "generate-routes": "tsr generate",
    "lint": "biome lint --write",
    "preview": "vite preview",
    "refresh": "rimraf node_modules .tanstack migrations src/generated && bun install && bun db:reset && bun generate && bun paraglide",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --pretty ",
    "ui": "bunx --bun shadcn@latest add"
  },
  "type": "module"
}
